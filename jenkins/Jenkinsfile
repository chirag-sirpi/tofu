pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    some-label: jenkins-agent
spec:
  containers:
  - name: sonar
    image: sonarsource/sonar-scanner-cli:latest
    command:
    - sleep
    args:
    - 99d
  - name: trivy
    image: aquasec/trivy:latest
    command:
    - sleep
    args:
    - 99d
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - sleep
    args:
    - 99d
  - name: git-tools
    image: alpine/git:latest
    command:
    - sleep
    args:
    - 99d
  - name: zap
    image: ghcr.io/zaproxy/zaproxy:stable
    command:
    - sleep
    args:
    - 99d
'''
        }
    }

    triggers {
        githubPush()
    }

    environment {
        REGISTRY = "us-central1-docker.pkg.dev/terraform-460705/devsecops-repo"
        IMAGE_NAME = "flask-app"
        IMAGE_TAG = "${BUILD_NUMBER}"
        SKIP_CI = "false"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Cloning repository..."
                checkout scm
                script {
                    def commitMsg = sh(script: 'git log -1 --pretty=%B', returnStdout: true).trim()
                    echo "Latest commit: ${commitMsg}"
                    if (commitMsg.contains('[skip ci]')) {
                        echo "Detected [skip ci] in commit message. Skipping subsequent stages."
                        env.SKIP_CI = "true"
                    }
                }
            }
        }

        stage('SonarQube SAST') {
            when {
                environment name: 'SKIP_CI', value: 'false'
            }
            steps {
                container('sonar') {
                    withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                        sh """
                        sonar-scanner \
                          -Dsonar.projectKey=devsecops-flask \
                          -Dsonar.sources=app/ \
                          -Dsonar.host.url=http://sonarqube-sonarqube.sonarqube.svc.cluster.local:9000 \
                          -Dsonar.token=\${SONAR_TOKEN}
                        """
                    }
                }
            }
        }

        stage('Build & Push Image') {
            when {
                environment name: 'SKIP_CI', value: 'false'
            }
            steps {
                container('kaniko') {
                    withCredentials([file(credentialsId: 'artifact-registry-key', variable: 'GOOGLE_APPLICATION_CREDENTIALS')]) {
                        sh "/kaniko/executor --context=app --dockerfile=app/Dockerfile --destination=\${REGISTRY}/\${IMAGE_NAME}:\${IMAGE_TAG} --destination=\${REGISTRY}/\${IMAGE_NAME}:latest"
                    }
                }
            }
        }

        stage('Trivy Container Scan') {
            when {
                environment name: 'SKIP_CI', value: 'false'
            }
            steps {
                container('trivy') {
                    withCredentials([file(credentialsId: 'artifact-registry-key', variable: 'GOOGLE_APPLICATION_CREDENTIALS')]) {
                        sh "trivy image --exit-code 1 --severity HIGH,CRITICAL --no-progress \${REGISTRY}/\${IMAGE_NAME}:\${IMAGE_TAG}"
                    }
                }
            }
        }

        stage('ArgoCD GitOps Trigger') {
            when {
                environment name: 'SKIP_CI', value: 'false'
            }
            steps {
                container('git-tools') {
                    withCredentials([string(credentialsId: 'github-token', variable: 'GH_TOKEN')]) {
                        sh """
                        git config --global --add safe.directory '*'
                        git config user.name 'Jenkins CI'
                        git config user.email 'jenkins@jenkins.local'
                        sed -i "s|image: ${env.REGISTRY}/${env.IMAGE_NAME}:.*|image: ${env.REGISTRY}/${env.IMAGE_NAME}:${env.IMAGE_TAG}|g" k8s/deployment.yaml
                        git add k8s/deployment.yaml
                        if ! git diff --quiet HEAD; then
                            git commit -m "chore: bump image tag to ${env.IMAGE_TAG} [skip ci]"
                            git push https://${env.GH_TOKEN}@github.com/chirag-sirpi/tofu.git HEAD:main
                        else
                            echo "No changes to deployment manifest."
                        fi
                        """
                    }
                }
            }
        }

        stage('OWASP ZAP DAST') {
            when {
                environment name: 'SKIP_CI', value: 'false'
            }
            steps {
                container('zap') {
                    sh """
                    zap-api-scan.py \
                      -t http://devsecops-flask.flask-app.svc.cluster.local/metrics \
                      -f openapi \
                      -r zap_report.html || true
                    """
                }
                publishHTML([allowMissing: false, alwaysLinkToLastBuild: true, keepAll: true, reportDir: '.', reportFiles: 'zap_report.html', reportName: 'OWASP ZAP DAST Report', reportTitles: ''])
            }
        }
    }

    post {
        always {
            container('git-tools') {
                sh 'rm -rf * .[^.]* || true'
            }
        }
        failure {
            echo "Security Pipeline failed. Deployment blocked!"
        }
        success {
            echo "Security Pipeline completed successfully. Deployment succeeded!"
        }
    }
}
