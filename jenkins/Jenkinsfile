def skipCi = false

pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    some-label: jenkins-agent
spec:
  serviceAccountName: jenkins
  volumes:
  - name: trivy-cache
    emptyDir: {}
  containers:
  - name: sonar
    image: sonarsource/sonar-scanner-cli:latest
    command:
    - sleep
    args:
    - 99d
  - name: trivy
    image: aquasec/trivy:latest
    command:
    - sleep
    args:
    - 99d
    volumeMounts:
    - name: trivy-cache
      mountPath: /root/.cache/trivy
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - sleep
    args:
    - 99d
  - name: git-tools
    image: alpine/git:latest
    command:
    - sleep
    args:
    - 99d
  - name: zap
    image: ghcr.io/zaproxy/zaproxy:stable
    command:
    - sleep
    args:
    - 99d
  - name: vault-agent
    image: hashicorp/vault:latest
    command:
    - sleep
    args:
    - 99d
    env:
    - name: VAULT_ADDR
      value: "http://vault.vault.svc.cluster.local:8200"
'''
        }
    }

    options {
        disableConcurrentBuilds()
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '15', artifactNumToKeepStr: '5'))
    }

    triggers {
        githubPush()
    }

    environment {
        REGISTRY              = "us-central1-docker.pkg.dev/terraform-460705/devsecops-repo"
        IMAGE_NAME            = "flask-app"
        IMAGE_TAG             = "${BUILD_NUMBER}"
        GITHUB_WEBHOOK_SECRET = credentials('github-webhook-secret')
        VAULT_ADDR            = "http://vault.vault.svc.cluster.local:8200"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Cloning repository..."
                checkout scm
                script {
                    def commitMsg = sh(script: 'git log -1 --pretty=%B', returnStdout: true).trim()
                    echo "Latest commit: ${commitMsg}"
                    if (commitMsg.contains('[skip ci]')) {
                        echo "Detected [skip ci] in commit message. Skipping subsequent stages."
                        skipCi = true
                    }
                }
            }
        }

        stage('Fetch Secrets from Vault') {
            when { expression { !skipCi } }
            steps {
                container('vault-agent') {
                    withCredentials([string(credentialsId: 'vault-token', variable: 'VAULT_TOKEN')]) {
                        script {
                            def sonarToken = sh(
                                script: "vault kv get -field=token secret/sonarqube 2>/dev/null || echo 'VAULT_UNAVAILABLE'",
                                returnStdout: true
                            ).trim()
                            if (sonarToken == 'VAULT_UNAVAILABLE') {
                                echo "Vault unavailable — falling back to Jenkins credential store."
                            } else {
                                echo "Fetched SonarQube token from Vault."
                                env.VAULT_SONAR_TOKEN = sonarToken
                            }
                        }
                    }
                }
            }
        }

        stage('Build & Push Image') {
            when { expression { !skipCi } }
            steps {
                container('kaniko') {
                    withCredentials([file(credentialsId: 'artifact-registry-key', variable: 'GOOGLE_APPLICATION_CREDENTIALS')]) {
                        // Kaniko layer cache stored in Artifact Registry — skips unchanged layers
                        sh """/kaniko/executor \\
                          --context=app \\
                          --dockerfile=app/Dockerfile \\
                          --destination=\${REGISTRY}/\${IMAGE_NAME}:\${IMAGE_TAG} \\
                          --destination=\${REGISTRY}/\${IMAGE_NAME}:latest \\
                          --cache=true \\
                          --cache-ttl=24h \\
                          --cache-repo=\${REGISTRY}/cache
                        """
                    }
                }
            }
        }

        // IMPROVEMENT: SonarQube SAST + Trivy scan run IN PARALLEL — saves ~90s per build
        stage('Security Scan (Parallel)') {
            when { expression { !skipCi } }
            parallel {
                stage('SonarQube SAST') {
                    steps {
                        container('sonar') {
                            withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                                sh """
                                sonar-scanner \\
                                  -Dsonar.projectKey=devsecops-flask \\
                                  -Dsonar.sources=app/ \\
                                  -Dsonar.host.url=http://sonarqube-sonarqube.sonarqube.svc.cluster.local:9000 \\
                                  -Dsonar.token=\${SONAR_TOKEN} \\
                                  -Dsonar.qualitygate.wait=true \\
                                  -Dsonar.qualitygate.timeout=300
                                """
                            }
                        }
                    }
                }
                stage('Trivy Container Scan') {
                    steps {
                        container('trivy') {
                            withCredentials([file(credentialsId: 'artifact-registry-key', variable: 'GOOGLE_APPLICATION_CREDENTIALS')]) {
                                sh """
                                trivy image \\
                                  --exit-code 1 \\
                                  --severity HIGH,CRITICAL \\
                                  --no-progress \\
                                  --cache-dir /root/.cache/trivy \\
                                  \${REGISTRY}/\${IMAGE_NAME}:\${IMAGE_TAG}
                                """
                            }
                        }
                    }
                }
            }
        }

        // Blue-Green: update Argo Rollout image tag — Argo Rollouts handles the traffic switch
        stage('ArgoCD GitOps Trigger') {
            when { expression { !skipCi } }
            steps {
                container('git-tools') {
                    withCredentials([string(credentialsId: 'github-token', variable: 'GH_TOKEN')]) {
                        sh """
                        git config --global --add safe.directory '*'
                        git config user.name 'Jenkins CI'
                        git config user.email 'jenkins@jenkins.local'
                        # Update Rollout image (blue-green strategy — Argo Rollouts controls traffic)
                        sed -i "s|image: ${env.REGISTRY}/${env.IMAGE_NAME}:.*|image: ${env.REGISTRY}/${env.IMAGE_NAME}:${env.IMAGE_TAG}|g" k8s/rollout.yaml
                        git add k8s/rollout.yaml
                        if ! git diff --quiet HEAD; then
                            git commit -m "chore: bump rollout image to ${env.IMAGE_TAG} [skip ci]"
                            git push https://${env.GH_TOKEN}@github.com/chirag-sirpi/tofu.git HEAD:main
                        else
                            echo "No changes to rollout manifest."
                        fi
                        """
                    }
                }
            }
        }

        stage('OWASP ZAP DAST') {
            when { expression { !skipCi } }
            steps {
                container('zap') {
                    sh """
                    zap-api-scan.py \\
                      -t http://devsecops-flask.flask-app.svc.cluster.local/metrics \\
                      -f openapi \\
                      -r zap_report.html || true
                    """
                }
                publishHTML([allowMissing: false, alwaysLinkToLastBuild: true, keepAll: true, reportDir: '.', reportFiles: 'zap_report.html', reportName: 'OWASP ZAP DAST Report', reportTitles: ''])
            }
        }
    }

    post {
        always {
            container('git-tools') {
                sh 'rm -rf * .[^.]* || true'
            }
        }
        failure {
            echo "Security Pipeline FAILED. Deployment blocked!"
        }
        success {
            echo "Security Pipeline completed successfully. Blue-Green promotion triggered!"
        }
    }
}
